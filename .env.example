# Скопируй этот файл в .env и заполни своими данными
# На Railway.app эти переменные вводятся в разделе Variables

# Яндекс Геокодер API ключ
# Получить: https://developer.tech.yandex.ru → создай проект → выбери "Геокодирование"
YANDEX_GEOCODER_KEY=сюда_вставь_ключ_геокодера

# Яндекс Доставка токен (Bearer token)
# Получить: https://b2b.taxi.yandex.ru → Настройки → API
YANDEX_DELIVERY_TOKEN=сюда_вставь_токен_доставки

# ManyChat API ключ
# Получить: ManyChat → Settings → API → Скопировать токен
MANYCHAT_API_KEY=сюда_вставь_ключ_manychat

# Координаты вашего магазина
# Как узнать: открой Яндекс Карты → найди магазин → правая кнопка мыши → "Что здесь?"
SHOP_LONGITUDE=69.5765
SHOP_LATITUDE=42.3417

# Название магазина
SHOP_NAME=Наш магазин
